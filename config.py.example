# Configuration file for BulbashTV
# Copy this file to config.py and fill in your API key

# TMDB API Configuration
# Get your API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY = "your_tmdb_api_key_here"

# Custom DNS (leave empty to use system DNS)
# Recommended: "8.8.8.8" (Google), "1.1.1.1" (Cloudflare), "9.9.9.9" (Quad9)
CUSTOM_DNS = ""

# TMDB API Base URL
TMDB_BASE_URL = "https://api.themoviedb.org/3"

# Torrent download directory (optional)
# Leave empty to use system temp directory
# Example: "/home/user/Downloads" or "./downloads"
TORRENT_DOWNLOAD_DIR = ""
